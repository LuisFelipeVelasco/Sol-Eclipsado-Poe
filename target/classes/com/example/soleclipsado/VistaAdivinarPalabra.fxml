<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="AnchorRoot" prefHeight="400.0" prefWidth="400.0" style="-fx-border-color: black;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.soleclipsado.PlayController">

   <children>

      <VBox alignment="TOP_CENTER" layoutX="4.0" layoutY="3.0" prefHeight="394.0" prefWidth="393.0" style="-fx-background-color: white;">

         <children>

            <ImageView fx:id="imageSol" fitHeight="100.0" fitWidth="119.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@IMAGENES/Sol_1.png" />
               </image>
            </ImageView>

            <Label style="-fx-font-size: 20;" text="Adivina la palabra:">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </Label>
            <HBox fx:id="hbox" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="52.0" prefWidth="370.0">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>

            <Label fx:id="AdvertenciaText" alignment="CENTER" contentDisplay="CENTER" prefHeight="25.0" prefWidth="365.0" style="-fx-text-fill: red; -fx-font-size: 15;" textAlignment="CENTER">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Label>

            <Button maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onActionButtonClicked" prefHeight="37.0" prefWidth="215.0" style="-fx-font-size: 18; -fx-background-color: EDCD81; -fx-border-width: 2;" text="Obtener Pista">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </Button>

         </children>

         <padding>
            <Insets bottom="20.0" top="20.0" />
         </padding>

      </VBox>

   </children>

</AnchorPane>
