<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #16213e, #0f3460);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.soleclipsado.HelloController">

   <children>

      <VBox alignment="TOP_CENTER" layoutX="0.0" layoutY="0.0" prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: transparent;">

         <children>

            <!-- Imagen del Sol con sombra dorada -->
            <ImageView fitHeight="126.0" fitWidth="134.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@IMAGENES/Sol_1.png" />
               </image>
               <effect>
                  <DropShadow color="#EDCD81" offsetX="0" offsetY="0" radius="25.0" spread="0.1" />
               </effect>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </ImageView>

            <!-- Título del juego -->
            <Label style="-fx-font-size: 13; -fx-font-family: 'Georgia'; -fx-text-fill: #EDCD81;                       -fx-font-style: italic; -fx-opacity: 0.75; -fx-letter-spacing: 3;" text="Sol Eclipsado">
               <VBox.margin>
                  <Insets top="4.0" />
               </VBox.margin>
            </Label>

            <!-- Label instrucción principal -->
            <Label style="-fx-font-size: 18; -fx-font-family: 'Georgia'; -fx-font-weight: bold;                       -fx-text-fill: #F0E6D3; -fx-letter-spacing: 1;" text="Escribe tu palabra secreta:">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>

            <!-- TextField rediseñado -->
            <TextField fx:id="palabraField" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="44.0" prefWidth="225.0" style="-fx-font-size: 20;                       -fx-font-family: 'Georgia';                       -fx-background-color: rgba(255,255,255,0.08);                       -fx-border-color: #EDCD81;                       -fx-border-width: 2;                       -fx-border-radius: 8;                       -fx-background-radius: 8;                       -fx-text-fill: #FFFFFF;                       -fx-prompt-text-fill: rgba(237,205,129,0.5);                       -fx-padding: 6 12 6 12;">
               <VBox.margin>
                  <Insets top="14.0" />
               </VBox.margin>
            </TextField>

            <!-- Label de advertencia/error -->
            <Label fx:id="welcomeText" style="-fx-text-fill: #FF7B7B; -fx-font-size: 13;                       -fx-font-family: 'Georgia'; -fx-font-style: italic;">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>

            <!-- Botón JUGAR con efecto Von Restorff: destaca sobre todo -->
            <Button maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#ButtonClicked" prefHeight="44.0" prefWidth="215.0" style="-fx-font-size: 17;                       -fx-font-family: 'Georgia';                       -fx-font-weight: bold;                       -fx-letter-spacing: 2;                       -fx-background-color: linear-gradient(to right, #EDCD81, #F5A623);                       -fx-text-fill: #1a1a2e;                       -fx-border-width: 0;                       -fx-background-radius: 22;                       -fx-cursor: hand;                       -fx-effect: dropshadow(gaussian, rgba(237,205,129,0.6), 16, 0.3, 0, 3);" text="✦  JUGAR  ✦">
               <VBox.margin>
                  <Insets top="25.0" />
               </VBox.margin>
            </Button>

         </children>

         <padding>
            <Insets bottom="20.0" top="10.0" />
         </padding>

      </VBox>

   </children>

</AnchorPane>
