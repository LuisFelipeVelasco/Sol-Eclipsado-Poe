<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="AnchorRoot" prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #16213e, #0f3460);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.soleclipsado.PlayController">

   <children>

      <VBox alignment="TOP_CENTER" layoutX="0.0" layoutY="0.0" prefHeight="400.0" prefWidth="400.0" style="-fx-background-color: transparent;">

         <children>

            <!-- Imagen del Sol con halo suave: feedback visual del estado del juego -->
            <ImageView fx:id="imageSol" fitHeight="133.0" fitWidth="128.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@IMAGENES/Sol_1.png" />
               </image>
               <effect>
                  <DropShadow color="#EDCD81" offsetX="0" offsetY="0" radius="20.0" spread="0.08" />
               </effect>
               <VBox.margin>
                  <Insets top="18.0" />
               </VBox.margin>
            </ImageView>

            <!-- Subtítulo ambiental -->
            <Label style="-fx-font-size: 12; -fx-font-family: 'Georgia'; -fx-text-fill: #EDCD81;                       -fx-font-style: italic; -fx-opacity: 0.65;" text="Sol Eclipsado">
               <VBox.margin>
                  <Insets top="3.0" />
               </VBox.margin>
            </Label>

            <!-- Instrucción del juego: clara y prominente -->
            <Label style="-fx-font-size: 19; -fx-font-family: 'Georgia'; -fx-font-weight: bold;                       -fx-text-fill: #F0E6D3; -fx-letter-spacing: 1;" text="Adivina la palabra:">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>

            <!-- HBox de letras: zona de juego principal con borde decorativo -->
            <HBox fx:id="hbox" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="52.0" prefWidth="370.0" style="-fx-background-color: rgba(255,255,255,0.05);                       -fx-border-color: rgba(237,205,129,0.25);                       -fx-border-width: 1;                       -fx-border-radius: 10;                       -fx-background-radius: 10;                       -fx-padding: 8;">
               <VBox.margin>
                  <Insets left="15.0" right="15.0" top="15.0" />
               </VBox.margin>
            </HBox>

            <!-- Label de advertencia: rojo cálido, menos agresivo -->
            <Label fx:id="AdvertenciaText" alignment="CENTER" contentDisplay="CENTER" prefHeight="25.0" prefWidth="365.0" style="-fx-text-fill: #FF8C69; -fx-font-size: 13;                       -fx-font-family: 'Georgia'; -fx-font-style: italic;" textAlignment="CENTER">
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Label>

            <!-- Botón Obtener Pista: Von Restorff — diferente, destacado, llamativo -->
            <Button maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#ButtonClicked" prefHeight="44.0" prefWidth="215.0" style="-fx-font-size: 16;                       -fx-font-family: 'Georgia';                       -fx-font-weight: bold;                       -fx-background-color: linear-gradient(to right, #EDCD81, #F5A623);                       -fx-text-fill: #1a1a2e;                       -fx-border-width: 0;                       -fx-background-radius: 22;                       -fx-cursor: hand;                       -fx-effect: dropshadow(gaussian, rgba(237,205,129,0.6), 16, 0.3, 0, 3);" text="Obtener Pista">
               <VBox.margin>
                  <Insets bottom="10.0" top="15.0" />
               </VBox.margin>
            </Button>

         </children>

         <padding>
            <Insets bottom="20.0" top="10.0" />
         </padding>

      </VBox>

   </children>

</AnchorPane>
